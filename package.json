{
  "name": "@missionsquad/mcp-grok",
  "version": "0.3.0",
  "description": "MissionSquad Grok MCP server for searching X.com with xAI.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": "./dist/server.js",
  "bin": {
    "mcp-grok": "./dist/server.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node ./dist/server.js",
    "dev": "tsx watch src/server.ts",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "grok",
    "xai",
    "x",
    "twitter",
    "missionsquad"
  ],
  "author": "MissionSquad",
  "license": "MIT",
  "dependencies": {
    "@missionsquad/fastmcp": "^1.1.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
